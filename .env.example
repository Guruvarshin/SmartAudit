# ---------------------------------------------------------------------------
# SmartAudit - environment configuration
# Copy to `.env` and adjust. Every variable the application reads is listed here.
# ---------------------------------------------------------------------------

# MongoDB connection string.
#
# Default targets the single-node replica set from docker-compose.yml:
#   docker compose up -d mongo
#
# MongoDB Atlas works as a drop-in replacement - nothing in the application
# depends on the local topology (no transactions are required anywhere):
#   MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/smartaudit
MONGODB_URI=mongodb://localhost:27017/smartaudit?replicaSet=rs0

# Express API server.
PORT=4000

# Background enrichment worker.
# WORKER_POLL_INTERVAL_MS - how long a drained worker sleeps before re-polling.
# WORKER_CONCURRENCY - parallel claim lanes inside one worker process; each
#                           lane claims one job at a time via an atomic
#                           findOneAndUpdate, so lanes (and extra worker
#                           processes) can never double-claim.
# WORKER_LEASE_MS - visibility timeout: a job still `processing` after
#                           this long is presumed orphaned by a crashed worker
#                           and becomes claimable again.
# WORKER_MAX_ATTEMPTS - claims after which a job is marked `failed`
#                           instead of retried (poison-job cutoff).
WORKER_POLL_INTERVAL_MS=1000
WORKER_CONCURRENCY=4
WORKER_LEASE_MS=60000
WORKER_MAX_ATTEMPTS=3

# Simulated ML model execution delay, in milliseconds.
# SPEC.md Scenario A mandates 400ms.
ENRICHMENT_DELAY_MS=400

# Batch size for the Scenario C model-migration CLI (`npm run migrate:models`).
# Bounds memory during keyset pagination over historical records.
MIGRATION_BATCH_SIZE=100

# Seed script defaults (overridable per-run with --count / --seed).
SEED_COUNT=500
SEED_RANDOM_SEED=20260720

# How long to wait for MongoDB before failing. The low default surfaces a
# forgotten `docker compose up` immediately; hosted clusters need longer for
# DNS and TLS on a cold start, so raise it to 30000 in a deployment.
# MONGO_TIMEOUT_MS=8000

# --- Model versions (Scenario C) -------------------------------------------
# Bump any of these, then run `npm run migrate:models` to page every historical
# record up to the new version. Left unset, the defaults below apply.
# RISK_MODEL_VERSION=risk-v1
# ANOMALY_MODEL_VERSION=anomaly-v1
# VECTOR_MODEL_VERSION=vec-v1
# COMPLIANCE_RULESET_VERSION=ifrs-ruleset-v1

# --- Risk context (Scenario D) ---------------------------------------------
# Shift a threshold, then run `npm run reevaluate:risk` to re-score every
# settled entry under the new context, leaving vectors untouched.
# RISK_THRESHOLD_MEDIUM=0.4
# RISK_THRESHOLD_HIGH=0.7
# APPROVAL_THRESHOLD=100000

# Deployment only. When true, `npm run start:server` also runs the enrichment
# worker in the same process - for single-instance hosting where you cannot run
# a second one. Leave unset locally and run `npm run start:worker` separately.
# RUN_WORKER_IN_PROCESS=true

# Client dev server.
# CLIENT_PORT - port the Vite dev server listens on.
# VITE_API_BASE_URL - where the dev server proxies /api requests (the Express
#                      server). The browser only ever talks same-origin to the
#                      client port; no CORS configuration is needed.
CLIENT_PORT=3000
VITE_API_BASE_URL=http://localhost:4000
